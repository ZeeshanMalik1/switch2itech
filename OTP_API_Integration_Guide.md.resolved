### Get Current User

```js
export const getMe = async () => {
  const response = await api.get('/auth/me');
  return response.data;
};
```

---

### Logout

```js
export const logout = async () => {
  await api.post('/auth/logout');
  localStorage.removeItem('token');
};
```

