## Frontend Code Examples

### Axios Base Instance (Recommended)

```js
// src/api/axiosInstance.js
import axios from 'axios';

const api = axios.create({
  baseURL: import.meta.env.VITE_API_URL || 'http://localhost:5000/api',
  withCredentials: true, // sends cookie automatically
  headers: { 'Content-Type': 'application/json' },
});

// Attach Bearer token from localStorage if available (fallback)
api.interceptors.request.use((config) => {
  const token = localStorage.getItem('token');
  if (token) config.headers.Authorization = `Bearer ${token}`;
  return config;
});

export default api;
```

---

### Step 1 — Request OTP

```js
// src/api/auth.js
import api from './axiosInstance';

export const requestOtp = async (identifier) => {
  const response = await api.post('/auth/request-otp', { identifier });
  return response.data;
};
```

```jsx
// React usage example
const [identifier, setIdentifier] = useState('');
const [loading, setLoading] = useState(false);

const handleRequestOtp = async () => {
  setLoading(true);
  try {
    await requestOtp(identifier);
    toast.success('OTP sent! Check your email or WhatsApp.');
    setStep('verify'); // move to OTP input screen
  } catch (err) {
    toast.error(err.response?.data?.message || 'Failed to send OTP');
  } finally {
    setLoading(false);
  }
};
```

---

### Step 2 — Verify OTP & Login

```js
export const verifyOtpLogin = async (identifier, otp) => {
  const response = await api.post('/auth/verify-otp-login', { identifier, otp });
  // Store token for Bearer fallback
  if (response.data.data?.token) {
    localStorage.setItem('token', response.data.data.token);
  }
  return response.data;
};
```

```jsx
// React usage example
const [otp, setOtp] = useState('');

const handleVerifyOtp = async () => {
  setLoading(true);
  try {
    const { data } = await verifyOtpLogin(identifier, otp);
    // data contains { _id, name, email, role, token }
    toast.success(`Welcome back, ${data.name}!`);
    navigate('/dashboard');
  } catch (err) {
    toast.error(err.response?.data?.message || 'Invalid or expired OTP');
  } finally {
    setLoading(false);
  }
};
```

---

### Register

```js
export const register = async (userData) => {
  const response = await api.post('/auth/register', userData);
  if (response.data.data?.token) {
    localStorage.setItem('token', response.data.data.token);
  }
  return response.data;
};
```

---

### Verify Email After Registration

```js
export const verifyEmail = async (code) => {
  const response = await api.post('/auth/verify-email', { code });
  return response.data;
};
```

```jsx
// React usage example — 6-digit OTP input
const handleVerifyEmail = async () => {
  try {
    await verifyEmail(emailCode);
    toast.success('Email verified successfully!');
  } catch (err) {
    toast.error(err.response?.data?.message || 'Invalid code');
  }
};
```

---

### Verify Phone After Registration

```js
export const verifyPhone = async (code) => {
  const response = await api.post('/auth/verify-phone', { code });
  return response.data;
};
```

